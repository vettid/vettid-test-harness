# VettID Test Configuration

# Application URLs
BASE_URL=https://vettid.dev/account
API_URL=https://api.vettid.dev

# AWS Cognito (Member Pool)
USER_POOL_ID=us-east-1_XXXXXXXXXXXX
CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
AWS_REGION=us-east-1

# DynamoDB Tables (for direct token retrieval)
MAGIC_LINK_TABLE=VettID-Infrastructure-MagicLinkTokens-XXXXXXXXXXXX

# AWS Cognito (Admin Pool)
ADMIN_USER_POOL_ID=us-east-1_XXXXXXXXXXXX
ADMIN_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# Email Testing (SES + S3)
EMAIL_BUCKET_NAME=vettid-test-emails-XXXXXXXXXXXX
TEST_EMAIL_DOMAIN=test.vettid.dev

# Test Admin Credentials (for admin API tests)
ADMIN_EMAIL=test-admin@vettid.dev
ADMIN_PASSWORD=

# Test Member Credentials (for member API tests)
# Option 1: Pre-generated token (fastest, but expires after 1 hour)
MEMBER_TOKEN=
# Option 2: Magic link flow via direct DynamoDB retrieval (recommended)
MEMBER_EMAIL=test-member@test.vettid.dev
# Note: Member auth uses magic link (no password) - token retrieved directly from DynamoDB

# Test Data
TEST_INVITE_CODE=VALID_INVITE_CODE_HERE

# AWS Credentials (for email retrieval and DynamoDB access)
# Uses default AWS CLI credentials from ~/.aws/credentials if not set
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
